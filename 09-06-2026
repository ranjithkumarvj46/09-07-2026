//FIND THE GREATEST OF THREE NUMBERS 
#include <stdio.h>

int main()
{
    int a, b, c, greatest;

    printf("Enter the three numbers: ");
    scanf("%d %d %d", &a, &b, &c);

    greatest = (a > b) ? ((a > c) ? a : c) : ((b > c) ? b : c);

    printf("Greatest number = %d\n", greatest);

    return 0;
}
