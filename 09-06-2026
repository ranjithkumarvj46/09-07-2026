//check whether a given number is positive, negative, or zero

#include <stdio.h>

int main()
{
    int a;

    printf("Enter the number: ");
    scanf("%d", &a);

    if (a > 0)
    {
        printf("Positive\n");
    }
    else if (a < 0)
    {
        printf("Negative\n");
    }
    else
    {
        printf("Zero\n");
    }

    return 0;
}
