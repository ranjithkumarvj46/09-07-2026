//Check whether a given number is a three-digit number using the if-else statement
#include <stdio.h>

int main()
{
    int a;

    printf("Enter the number: ");
    scanf("%d", &a);

    if ((a >= 100 && a <= 999) || (a <= -100 && a >= -999))
    {
        printf("It is a three-digit number.\n");
    }
    else
    {
        printf("It is not a three-digit number.\n");
    }

    return 0;
}

